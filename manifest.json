{
  "manifest_version": 3,
  "name": "ClaudeShift",
  "version": "2.0.0",
  "description": "Switch between Claude.ai accounts instantly. Save and restore multiple sessions.",
  "incognito": "spanning",
  "homepage_url": "https://codebysreyas.github.io/ClaudeShift/",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "windows"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ClaudeShift",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}